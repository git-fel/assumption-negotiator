# Virtual environment — never track this.
# Anyone who clones repo will create their own via: pip install -r requirements.txt
.venv/
venv/

# Python creates these automatically when code runs.
# They're cached bytecode files — not source code.
__pycache__/

# Environment variables file — may contain API key.
# NEVER commit secrets to Git.
.env

# macOS creates this hidden file in every folder you open in Finder.
# It stores things like icon positions — not relevant to project.
.DS_Store

# VSCode editor settings — personal to setup, not part of the project.
.vscode/